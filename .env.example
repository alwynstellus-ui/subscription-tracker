# ============================================================
# SUBSCRIPTION TRACKER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (get from https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (get from https://console.cloud.google.com → APIs & Services → Credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (get from https://portal.azure.com → App registrations)
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Anthropic Claude API (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key

# Encryption key for OAuth token storage (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-key
